{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SchoolConfig",
  "description": "User institution configuration schema, corresponding to ~/.config/lit-dl/school.json",
  "type": "object",
  "required": ["version", "school", "auth", "libraries"],
  "properties": {
    "version": {
      "type": "integer",
      "description": "Configuration version number for future migration",
      "const": 1
    },
    "school": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2,
          "description": "Full institution name"
        },
        "code": {
          "type": ["string", "null"],
          "description": "Institution code/abbreviation"
        },
        "configured_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "Configuration timestamp in ISO 8601"
        },
        "source": {
          "type": ["string", "null"],
          "enum": ["preset", "manual", "resource_url", null],
          "description": "Configuration source: resource URL / preset library / manual entry"
        }
      }
    },
    "auth": {
      "type": "object",
      "required": ["type", "sso_domain"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["cas", "jaccount", "uis", "ustp", "sso", "custom"],
          "description": "Authentication type"
        },
        "sso_domain": {
          "type": "string",
          "description": "Unified identity authentication domain, e.g., jaccount.sjtu.edu.cn"
        },
        "carsi_entry": {
          "type": ["string", "null"],
          "description": "CARSI federation authentication entry URL"
        },
        "carsi_sp_entity_id": {
          "type": ["string", "null"],
          "description": "CARSI SP EntityID (optional)"
        }
      }
    },
    "proxy": {
      "type": "object",
      "properties": {
        "type": {
          "type": ["string", "null"],
          "enum": ["ezproxy", null],
          "description": "Proxy type"
        },
        "ezproxy_url": {
          "type": ["string", "null"],
          "description": "EZproxy login address"
        }
      }
    },
    "libraries": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "List of databases subscribed by the institution with institutional access"
    },
    "discovery": {
      "type": "object",
      "properties": {
        "web_of_science_url": {
          "type": ["string", "null"],
          "description": "Web of Science / academic resource literature aggregation access service entry"
        },
        "resource_entry_url": {
          "type": ["string", "null"],
          "description": "Library electronic resource entry provided by user"
        },
        "resource_portal_url": {
          "type": ["string", "null"],
          "description": "Resource aggregation portal entry"
        },
        "auth_service_host": {
          "type": ["string", "null"],
          "description": "Authentication redirect service domain"
        }
      },
      "additionalProperties": true
    },
    "notes": {
      "type": "string",
      "default": "",
      "description": "Special notes"
    },
    "_warnings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Warnings generated during validation (non-blocking for writing)"
    }
  },
  "additionalProperties": false
}
